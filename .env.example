# Phase 1 не требует ключей: публичные OHLCV читаются без авторизации.
# Эти переменные понадобятся только в будущей фазе реального исполнения.
# НЕ коммитить реальный .env.

EXCHANGE_API_KEY=
EXCHANGE_API_SECRET=
# Биржа для будущего исполнения (НЕ mexc для розничных фьючерсов): bybit | okx | bitget | binance
EXECUTION_EXCHANGE=bybit
